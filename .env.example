# --- LLM (backend) ---
# stub = deterministic local output (default). real = OpenAI-compatible Chat Completions API.
# LLM_MODE=stub

# Required when LLM_MODE=real (non-empty). Never commit real secrets.
# OPENAI_API_KEY=

# Optional overrides when LLM_MODE=real (OpenAI-compatible servers supported).
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- CORS (backend) ---
# Optional: comma-separated origins allowed by backend CORS (defaults are set in docker-compose.yml).
# FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- Frontend ---
# Optional: API base URL as seen from the browser (defaults in docker-compose.yml for the frontend service).
# VITE_API_URL=http://localhost:8000
