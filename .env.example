# Copy this file to `.env` in the project root (next to docker-compose.yml).
# The backend service loads this file via `env_file` (see docker-compose.yml). Set OPENAI_API_KEY here
# for real mode—do not depend on shell exports for the API key (stale exports can override `.env`).
# Never commit `.env` or real API keys.

# --- LLM (backend) ---
# stub = deterministic local output (default). real = OpenAI-compatible Chat Completions API.
# In Docker Compose, set LLM_MODE here (env_file). Do not rely on shell exports for LLM_MODE.
LLM_MODE=stub

# Required when LLM_MODE=real: set your provider secret (non-empty). Unset or blank => HTTP 503 in real mode.
# OPENAI_API_KEY=

# Optional when LLM_MODE=real (OpenAI-compatible servers supported).
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Optional: 1 = request JSON object mode from the API (default). 0 = disable if your provider errors.
# OPENAI_JSON_OBJECT=1

# --- CORS (backend) ---
# Optional: comma-separated origins allowed by backend CORS (defaults are set in docker-compose.yml).
# FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- Frontend ---
# Optional: API base URL as seen from the browser (defaults in docker-compose.yml for the frontend service).
# VITE_API_URL=http://localhost:8000
